SPRING_PROFILES_ACTIVE=dev

# MongoDB Atlas (reemplaza con tu URI de Atlas en producción)
MONGODB_URI=mongodb://localhost:27017/geolocalization

# RabbitMQ (CloudAMQP)
RABBITMQ_HOST=woodpecker.rmq.cloudamqp.com
RABBITMQ_PORT=5671
RABBITMQ_USERNAME=thjdybjd
RABBITMQ_PASSWORD=changeme
RABBITMQ_VIRTUAL_HOST=thjdybjd
RABBITMQ_SSL=true

# JWT (debe coincidir con el secreto del auth-service)
JWT_SECRET=dev-secret-key-must-be-at-least-32-characters

# Servidor
SERVER_PORT=8083
SERVER_URL=http://localhost:8083

# URL del auth-service (para validaciones inter-servicio futuras)
AUTH_SERVICE_URL=http://localhost:8080

# Radio por defecto para búsqueda de usuarios cercanos (metros)
GEO_DEFAULT_RADIUS=500

# Google Maps Platform — Geocoding API
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_api_key_here
